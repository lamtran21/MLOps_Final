# Evidently Cloud (monitoring reports)
EVIDENTLY_API_TOKEN=your_evidently_api_token_here
EVIDENTLY_PROJECT_ID=your_evidently_project_id_here
EVIDENTLY_CLOUD_URL=https://app.evidently.cloud

# GitHub (production batch uploads from the API)
GITHUB_PAT=your_github_personal_access_token_here
GITHUB_REPO=your_github_username/MLOps_Final

# DagsHub (optional locally; required for DVC push in CI)
DAGSHUB_USERNAME=your_dagshub_username_here
DAGSHUB_TOKEN=your_dagshub_token_here

# Streamlit frontend (local dev; Docker Compose sets this automatically)
FASTAPI_URL=http://127.0.0.1:8000